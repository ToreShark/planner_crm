# ============================================================
# AI Planner — Environment Variables
# Скопируй этот файл: cp .env.example .env
# Заполни реальными значениями на сервере
# ============================================================

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Telegram Bot
TELEGRAM_BOT_TOKEN=7123456789:AAH-your-token-here
TELEGRAM_OWNER_ID=123456789

# PostgreSQL
DATABASE_URL=postgresql://planner:planner_secret@localhost:5432/primelegal
POSTGRES_USER=planner
POSTGRES_PASSWORD=planner_secret
POSTGRES_DB=primelegal

# App
NODE_ENV=production
PORT=3000
